SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app_db
SPRING_DATASOURCE_USERNAME=app
SPRING_DATASOURCE_PASSWORD=app_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
JWT_SECRET=change-me-to-a-32-byte-secret
SPRING_H2_CONSOLE_ENABLED=false
APP_SEED_DEMO_DATA=false
SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_DOCS_PUBLIC_ENABLED=false
APP_AUTH_REFRESH_COOKIE_NAME=fourthitek_refresh
APP_AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
APP_AUTH_REFRESH_COOKIE_DOMAIN=
APP_AUTH_REFRESH_COOKIE_SECURE=false
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax
APP_AUDIT_TRUST_FORWARDED_FOR=false
UPLOAD_DIR=./uploads
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf
UPLOAD_BASE_URL=/uploads
# SePay bank transfer integration.
# When SEPAY_ENABLED=true, ALL four variables below are required — the application
# will refuse to start if any of them is blank.
# Generate a strong random webhook token: openssl rand -hex 32
SEPAY_ENABLED=false
SEPAY_WEBHOOK_TOKEN=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=
APP_MAIL_ENABLED=false
APP_MAIL_FROM=
APP_MAIL_FROM_NAME=4ThiTek
APP_PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
APP_PASSWORD_RESET_EXPIRATION_MINUTES=30
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
APP_FCM_ENABLED=false
APP_FCM_PROJECT_ID=
APP_FCM_CREDENTIALS_PATH=C:/Users/your-user/.4thitek/secrets/service_account.json
APP_FCM_CREDENTIALS_JSON_BASE64=
