# Production environment — 4thitek
# Copy this file to .env and fill in every value before deploying.
# Run with: docker compose up -d
#
# Variables marked REQUIRED will cause startup failure if left empty.
# NEVER commit your actual .env file to version control.

# =============================================================================
# REQUIRED SECRETS — must be set before first deploy
# Generate secure values with: openssl rand -base64 48 | tr -d '\n'
# =============================================================================

# PostgreSQL credentials (must match between postgres service and backend)
POSTGRES_DB=app_db
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Redis auth password
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# JWT signing secret — minimum 32 chars, use a random string not a passphrase
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# MinIO object storage credentials
MINIO_ROOT_USER=CHANGE_ME_minio_admin_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=4thitek-uploads

# =============================================================================
# REQUIRED URLs — must match your actual deployment
# =============================================================================

# Public base URL where browsers fetch uploaded files (MinIO/CDN endpoint)
APP_STORAGE_S3_PUBLIC_BASE_URL=https://storage.4thitek.vn/4thitek-uploads

# Comma-separated list of allowed CORS origins (no trailing slash, no wildcards)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://4thitek.vn,https://www.4thitek.vn,https://admin.4thitek.vn

# Link base embedded in password-reset and staff-onboarding emails
APP_PASSWORD_RESET_BASE_URL=https://4thitek.vn/reset-password

# Public website base URL (used as build arg for dealer app)
PUBLIC_SITE_BASE_URL=https://4thitek.vn

# =============================================================================
# API URLs
# Defaults in docker-compose.yaml already point to api.4thitek.vn.
# Only set these if your domain differs.
# =============================================================================

NEXT_PUBLIC_API_ORIGIN=https://api.4thitek.vn
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_BASE_URL=https://api.4thitek.vn/api/v1
INTERNAL_API_ORIGIN=https://api.4thitek.vn
INTERNAL_API_VERSION=v1
INTERNAL_API_BASE_URL=https://api.4thitek.vn/api/v1
VITE_API_ORIGIN=https://api.4thitek.vn
VITE_API_VERSION=v1
VITE_API_BASE_URL=https://api.4thitek.vn/api/v1
API_ORIGIN=https://api.4thitek.vn
API_VERSION=v1
API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_API_ORIGIN=https://api.4thitek.vn
DEALER_API_VERSION=v1
DEALER_API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_WS_BASE_URL=https://ws.4thitek.vn

# =============================================================================
# SERVICE PORTS — change only if the defaults conflict with the host
# =============================================================================

BACKEND_PORT=8080
MAIN_FE_PORT=3000
ADMIN_FE_PORT=4173
DEALER_PORT=4174

# =============================================================================
# STORAGE — defaults target the MinIO container on the same host.
# Change APP_STORAGE_S3_ENDPOINT only if using an external S3-compatible service.
# =============================================================================

APP_STORAGE_PROVIDER=s3
APP_STORAGE_S3_ENDPOINT=http://minio:9000
APP_STORAGE_S3_REGION=ap-southeast-1
APP_STORAGE_S3_PATH_STYLE_ACCESS=true
UPLOAD_BASE_URL=/uploads

# =============================================================================
# BOOTSTRAP SUPER ADMIN — one-time first-deploy setup
#
# Set ENABLED=true only on the FIRST deploy to seed the initial super admin.
# After the first login and password change, set ENABLED=false and redeploy.
# Leaving ENABLED=true on a live system is a security risk.
# =============================================================================

APP_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
APP_BOOTSTRAP_SUPER_ADMIN_EMAIL=owner@yourdomain.com
APP_BOOTSTRAP_SUPER_ADMIN_PASSWORD=CHANGE_ME_initial_admin_password
APP_BOOTSTRAP_SUPER_ADMIN_NAME=System Owner

# =============================================================================
# AUTH COOKIE — adjust domain to match your deployment
# =============================================================================

APP_AUTH_REFRESH_COOKIE_NAME=fourthitek_refresh
APP_AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
APP_AUTH_REFRESH_COOKIE_DOMAIN=.4thitek.vn
APP_AUTH_REFRESH_COOKIE_SECURE=true
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax
APP_AUDIT_TRUST_FORWARDED_FOR=true

# =============================================================================
# SECURITY & PERFORMANCE
# =============================================================================

APP_SECURITY_REQUIRE_STRONG_JWT_SECRET=true
APP_SEED_DEMO_DATA=false
APP_DOCS_PUBLIC_ENABLED=false

APP_CACHE_PUBLIC_TTL_MINUTES=30
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_AUTH_REQUESTS=10
APP_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
APP_RATE_LIMIT_PASSWORD_RESET_REQUESTS=5
APP_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=300
APP_RATE_LIMIT_WARRANTY_LOOKUP_REQUESTS=30
APP_RATE_LIMIT_WARRANTY_LOOKUP_WINDOW_SECONDS=60
APP_RATE_LIMIT_UPLOAD_REQUESTS=20
APP_RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
APP_RATE_LIMIT_WEBHOOK_REQUESTS=120
APP_RATE_LIMIT_WEBHOOK_WINDOW_SECONDS=60
APP_RATE_LIMIT_TRUST_FORWARDED_FOR=true

SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_ENABLED=true
SPRING_DATA_REDIS_DATABASE=0
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

APP_ORDER_IDEMPOTENCY_TTL_MINUTES=10
APP_ORDER_PENDING_TIMEOUT_HOURS=48

# =============================================================================
# EMAIL — required for password reset and staff onboarding
# Leave APP_MAIL_ENABLED=false to disable email sending entirely.
# =============================================================================

APP_MAIL_ENABLED=false
APP_MAIL_FROM=
APP_MAIL_FROM_NAME=4ThiTek
APP_PASSWORD_RESET_EXPIRATION_MINUTES=30
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# =============================================================================
# SEPAY PAYMENT — leave ENABLED=false unless using bank transfer via SePay
# =============================================================================

SEPAY_ENABLED=false
SEPAY_WEBHOOK_TOKEN=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=

# =============================================================================
# ANALYTICS / MONITORING (optional)
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# =============================================================================
# FCM PUSH NOTIFICATIONS (optional)
# =============================================================================

APP_FCM_ENABLED=false
APP_FCM_PROJECT_ID=
APP_FCM_CREDENTIALS_PATH=
APP_FCM_CREDENTIALS_JSON_BASE64=
