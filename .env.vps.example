# =============================================================================
# 4thitek — VPS environment file (.env.vps)  [TEMPLATE]
#
# Copy to .env.vps and fill the real values. NEVER commit .env.vps.
#   cp .env.vps.example .env.vps
#
# Run on the VPS with (compose loads ONE env-file, so it must be COMPLETE):
#   docker compose --env-file .env.vps up -d --build
#
# IMPORTANT — build-time bake:
#   Every NEXT_PUBLIC_* / VITE_* / INTERNAL_* / API_* value below is baked into
#   the main-fe / admin-fe bundle at BUILD time. After changing any of them you
#   MUST rebuild (the `--build` flag above / `docker compose build --no-cache`),
#   a plain restart keeps the OLD urls.
#
# DEPLOYMENT MODEL (differs from a raw IP:port setup):
#   4thitek runs behind Nginx with HTTPS per subdomain — see deploy/nginx/*.conf:
#     https://4thitek.vn        -> main-fe   (127.0.0.1:3000)
#     https://admin.4thitek.vn  -> admin-fe  (127.0.0.1:4173)
#     https://api.4thitek.vn    -> backend   (127.0.0.1:8080)
#     https://ws.4thitek.vn     -> backend WS (127.0.0.1:8080)
#   Postgres / MinIO stay INTERNAL (loopback + docker network). The
#   browser never talks to them directly; uploads are streamed back through the
#   backend (api.4thitek.vn). Do NOT point browser urls at minio:9000.
#
# To deploy on a different domain: replace 4thitek.vn everywhere below AND run
# the sed steps in docs/CUSTOMIZE_DOMAIN.md for deploy/nginx/*.conf.
# =============================================================================

# =============================================================================
# REQUIRED SECRETS — must be set before first run (compose errors if missing)
# Generate: openssl rand -hex 16   (passwords)
#           openssl rand -hex 32   (JWT_SECRET — must be strong, prod refuses weak)
# =============================================================================

POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# =============================================================================
# DATABASE / OBJECT STORAGE (non-secret)
# =============================================================================

POSTGRES_DB=app_db
POSTGRES_USER=app
MINIO_BUCKET=4thitek-uploads

# =============================================================================
# SERVICE PORTS — must match the upstream ports in deploy/nginx/shared-config.conf
# All are bound to 127.0.0.1 by the compose file; Nginx is the only public entry.
# =============================================================================

BACKEND_PORT=8080
MAIN_FE_PORT=3000
ADMIN_FE_PORT=4173
DEALER_PORT=4174
MINIO_API_PORT=9000

# =============================================================================
# API URLS — production (baked into the frontend bundles at build time)
# NEXT_PUBLIC_* / VITE_* / API_* -> browser-reachable public api domain.
# INTERNAL_* -> docker-network hostname, stays http://backend:8080.
# =============================================================================

NEXT_PUBLIC_API_ORIGIN=https://api.4thitek.vn
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_BASE_URL=https://api.4thitek.vn/api/v1
INTERNAL_API_ORIGIN=http://backend:8080
INTERNAL_API_VERSION=v1
INTERNAL_API_BASE_URL=http://backend:8080/api/v1

# ISR on-demand revalidation (backend -> main-fe). REVALIDATE_SECRET phai giong nhau o ca
# hai service. Sinh bang: openssl rand -hex 32. De trong = tat (chi ISR time-based).
MAIN_FE_INTERNAL_URL=http://main-fe:3000
REVALIDATE_SECRET=CHANGE_ME_64_HEX_CHARS
VITE_API_ORIGIN=https://api.4thitek.vn
VITE_API_VERSION=v1
VITE_API_BASE_URL=https://api.4thitek.vn/api/v1
API_ORIGIN=https://api.4thitek.vn
API_VERSION=v1
API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_API_ORIGIN=https://api.4thitek.vn
DEALER_API_VERSION=v1
DEALER_API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_WS_BASE_URL=wss://ws.4thitek.vn
PUBLIC_SITE_BASE_URL=https://4thitek.vn

# =============================================================================
# REVERSE-PROXY REQUIRED (production checklist — docs/DEPLOYMENT_GUIDE.md §6)
# Behind Nginx the backend sees 127.0.0.1 as the client; these make audit log,
# rate limiting, CORS and cross-subdomain sessions work correctly.
# Only enable TRUST_FORWARDED_FOR when the backend is truly behind a trusted proxy.
# =============================================================================

APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://4thitek.vn,https://admin.4thitek.vn
APP_CORS_ALLOW_CREDENTIALS=true
APP_AUDIT_TRUST_FORWARDED_FOR=true
APP_RATE_LIMIT_TRUST_FORWARDED_FOR=true
APP_AUTH_REFRESH_COOKIE_NAME=fourthitek_refresh
APP_AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
# Leading dot is required so the refresh cookie is shared across subdomains.
APP_AUTH_REFRESH_COOKIE_DOMAIN=.4thitek.vn
APP_AUTH_REFRESH_COOKIE_SECURE=true
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax

# =============================================================================
# AUTH / EMAIL LINK BASE URLS (sent inside emails — must point to real domain)
# =============================================================================

APP_PASSWORD_RESET_BASE_URL=https://4thitek.vn/reset-password
APP_ADMIN_PASSWORD_RESET_BASE_URL=https://admin.4thitek.vn/reset-password
APP_PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_EMAIL_VERIFICATION_BASE_URL=https://admin.4thitek.vn/verify-email
APP_EMAIL_VERIFICATION_EXPIRATION_MINUTES=60

# =============================================================================
# PRODUCTION HARDENING — keep these as-is for public traffic
# =============================================================================

APP_SEED_DEMO_DATA=false
APP_SEED_DEMO_PASSWORD=
APP_DOCS_PUBLIC_ENABLED=false
APP_SECURITY_REQUIRE_STRONG_JWT_SECRET=true
# Keep false. Set true only for one-time emergency bootstrap in production.
APP_ALLOW_PRODUCTION_BOOTSTRAP=false

# --- First-deploy SUPER_ADMIN bootstrap (docs/DEPLOYMENT_GUIDE.md §3) ---
# Enable ONLY on the very first deploy, log in, change password, then set the
# flag back to false + clear the password and redeploy.
APP_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
APP_BOOTSTRAP_SUPER_ADMIN_EMAIL=
APP_BOOTSTRAP_SUPER_ADMIN_PASSWORD=
APP_BOOTSTRAP_SUPER_ADMIN_NAME=System Owner

# =============================================================================
# STORAGE — MinIO stays internal; public assets are proxied via the backend.
# =============================================================================

APP_STORAGE_PROVIDER=s3
APP_STORAGE_S3_ENDPOINT=http://minio:9000
# Presign endpoint stays empty: uploads are proxied through the backend, not
# direct browser->MinIO (MinIO is not published publicly).
APP_STORAGE_S3_PRESIGN_ENDPOINT=
APP_STORAGE_S3_REGION=ap-southeast-1
APP_STORAGE_S3_PATH_STYLE_ACCESS=true
# Empty -> media served via api.4thitek.vn/api/v1/media/{id}/download &
# /api/v1/upload/**. Only set this if you expose MinIO on its own public URL.
APP_STORAGE_S3_PUBLIC_BASE_URL=
UPLOAD_BASE_URL=/uploads

# =============================================================================
# SPRING RUNTIME (production-safe defaults — Flyway on, DDL validate)
# =============================================================================

SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=1
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# =============================================================================
# BUSINESS TIMINGS & RATE LIMITS (defaults are production-safe)
# =============================================================================

APP_CACHE_PUBLIC_TTL_MINUTES=30
APP_ORDER_IDEMPOTENCY_TTL_MINUTES=10
APP_ORDER_PENDING_TIMEOUT_HOURS=48
APP_ORDER_STALE_CHECK_INTERVAL_MS=3600000
APP_ORDER_STALE_WARNING_BEFORE_HOURS=6
APP_PAYMENT_LARGE_AMOUNT_PROOF_THRESHOLD=10000000
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_AUTH_REQUESTS=10
APP_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
APP_RATE_LIMIT_PASSWORD_RESET_REQUESTS=5
APP_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=300
APP_RATE_LIMIT_WARRANTY_LOOKUP_REQUESTS=30
APP_RATE_LIMIT_WARRANTY_LOOKUP_WINDOW_SECONDS=60
APP_RATE_LIMIT_UPLOAD_REQUESTS=20
APP_RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
APP_RATE_LIMIT_WEBHOOK_REQUESTS=120
APP_RATE_LIMIT_WEBHOOK_WINDOW_SECONDS=60

# =============================================================================
# EMAIL (optional — leave APP_MAIL_ENABLED=false to skip)
# =============================================================================

APP_MAIL_ENABLED=false
APP_MAIL_FROM=info@4thitek.vn
APP_MAIL_FROM_NAME=4T HITEK
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# =============================================================================
# SEPAY bank-transfer reconciliation (optional — set SEPAY_ENABLED=true to use;
# then ALL four vars below are required). Webhook: openssl rand -hex 32
# =============================================================================

SEPAY_ENABLED=false
SEPAY_WEBHOOK_TOKEN=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=

# =============================================================================
# FIREBASE / FCM push (optional — leave APP_FCM_ENABLED=false to skip)
# Base64 of service_account.json:  base64 -w 0 service_account.json
# =============================================================================

APP_FCM_ENABLED=false
APP_FCM_PROJECT_ID=
APP_FCM_CREDENTIALS_JSON_BASE64=

# =============================================================================
# ANALYTICS / MONITORING (optional)
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
