# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.production
backend/.env
admin-fe/.env
main-fe/.env
dealer/.env
service_account.json
service_account*.json
google-services.json
dealer/android/app/google-services.json
dealer/ios/Runner/GoogleService-Info.plist

# ── Node dependencies ────────────────────────────────────────────────────────
# Root package.json is a local tooling helper; its node_modules must never be
# committed. Each app subdirectory manages its own node_modules via its own
# .gitignore.
node_modules/

# ── Claude Code / IDE tool artifacts ─────────────────────────────────────────
# .playwright-cli/ and output/ are written by the Claude Code browser
# automation tool during development sessions. They contain session logs and
# are entirely regenerated on each run — never source of truth.
.playwright-cli/
output/

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# P0 production safety
.env*
**/.env*
!.env.example
!**/.env.example
*.save
*.jks
*.keystore
key.properties
**/key.properties
service_account*.json
google-services.json
**/google-services.json
link.txt
link_auth.txt
**/link*.txt
**/*secret*dump*.txt
**/*token*dump*.txt
**/*auth*dump*.txt

# ── Local dev / working artifacts ─────────────────────────────────────────────
# tmp/ contains working files from design audits, brand review sessions, etc.
tmp/
# backups/ contains local DB/MinIO snapshots from the backup.sh script.
# Never commit production backups to the repo — store encrypted off-site.
backups/
# backend/uploads/ is the local file upload directory (dev / Docker volume mount).
# Real uploads live in MinIO in staging/production; this path must never be committed.
backend/uploads/
