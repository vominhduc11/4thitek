# .env.example — Local / Staging template
#
# Used with: docker compose up -d  (docker-compose.yaml)
#
# SETUP:
#   cp .env.example .env
#   # Edit the five REQUIRED SECRETS below, then run docker compose up -d.
#
# This file is a template. The actual .env file must NOT be committed to git.

# =============================================================================
# REQUIRED SECRETS — must be changed before first run
# Leaving these as-is will cause docker compose to fail with a clear error.
# =============================================================================

POSTGRES_PASSWORD=change-me-strong-db-password
REDIS_PASSWORD=change-me-strong-redis-password
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DATABASE (non-secret, defaults are fine for local)
# =============================================================================

POSTGRES_DB=app_db
POSTGRES_USER=app

# =============================================================================
# OBJECT STORAGE
# =============================================================================

MINIO_BUCKET=4thitek-uploads

# =============================================================================
# SERVICE PORTS (change only if the defaults conflict with your host)
# =============================================================================

BACKEND_PORT=8080
MAIN_FE_PORT=3000
ADMIN_FE_PORT=4173
DEALER_PORT=4174
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# API URLS (used as build args for frontend images)
# =============================================================================

NEXT_PUBLIC_API_ORIGIN=https://api.4thitek.vn
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_BASE_URL=https://api.4thitek.vn/api/v1
INTERNAL_API_ORIGIN=https://api.4thitek.vn
INTERNAL_API_VERSION=v1
INTERNAL_API_BASE_URL=https://api.4thitek.vn/api/v1
VITE_API_ORIGIN=https://api.4thitek.vn
VITE_API_VERSION=v1
VITE_API_BASE_URL=https://api.4thitek.vn/api/v1
API_ORIGIN=https://api.4thitek.vn
API_VERSION=v1
API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_API_ORIGIN=https://api.4thitek.vn
DEALER_API_VERSION=v1
DEALER_API_BASE_URL=https://api.4thitek.vn/api/v1
DEALER_WS_BASE_URL=https://ws.4thitek.vn
PUBLIC_SITE_BASE_URL=https://4thitek.vn

# =============================================================================
# APP SETTINGS
# =============================================================================

APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://4thitek.vn,https://www.4thitek.vn,https://admin.4thitek.vn
APP_PASSWORD_RESET_BASE_URL=https://4thitek.vn/reset-password
APP_PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_SEED_DEMO_DATA=false

# Bootstrap super admin — enable ONLY on first deploy, then set back to false.
APP_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
APP_BOOTSTRAP_SUPER_ADMIN_EMAIL=
APP_BOOTSTRAP_SUPER_ADMIN_PASSWORD=
APP_BOOTSTRAP_SUPER_ADMIN_NAME=System Owner

APP_DOCS_PUBLIC_ENABLED=false
APP_AUTH_REFRESH_COOKIE_NAME=fourthitek_refresh
APP_AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
APP_AUTH_REFRESH_COOKIE_DOMAIN=
APP_AUTH_REFRESH_COOKIE_SECURE=true
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax
APP_AUDIT_TRUST_FORWARDED_FOR=false
UPLOAD_BASE_URL=/uploads
APP_STORAGE_PROVIDER=s3
APP_STORAGE_S3_ENDPOINT=http://minio:9000
APP_STORAGE_S3_REGION=ap-southeast-1
APP_STORAGE_S3_PATH_STYLE_ACCESS=true
APP_STORAGE_S3_PUBLIC_BASE_URL=https://storage.4thitek.vn/4thitek-uploads
SPRING_DATA_REDIS_DATABASE=0
SPRING_FLYWAY_ENABLED=true
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000
APP_CACHE_PUBLIC_TTL_MINUTES=30
APP_SECURITY_REQUIRE_STRONG_JWT_SECRET=true
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_AUTH_REQUESTS=10
APP_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
APP_RATE_LIMIT_PASSWORD_RESET_REQUESTS=5
APP_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=300
APP_RATE_LIMIT_WARRANTY_LOOKUP_REQUESTS=30
APP_RATE_LIMIT_WARRANTY_LOOKUP_WINDOW_SECONDS=60
APP_RATE_LIMIT_UPLOAD_REQUESTS=20
APP_RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
APP_RATE_LIMIT_WEBHOOK_REQUESTS=120
APP_RATE_LIMIT_WEBHOOK_WINDOW_SECONDS=60
APP_RATE_LIMIT_TRUST_FORWARDED_FOR=false

# =============================================================================
# EMAIL (optional — leave APP_MAIL_ENABLED=false to skip)
# =============================================================================

APP_MAIL_ENABLED=false
APP_MAIL_FROM=
APP_MAIL_FROM_NAME=4ThiTek
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# =============================================================================
# SEPAY (optional — leave SEPAY_ENABLED=false to skip)
# When SEPAY_ENABLED=true, ALL four variables below are required.
# Generate webhook token with: openssl rand -hex 32
# =============================================================================

SEPAY_ENABLED=false
SEPAY_WEBHOOK_TOKEN=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=

# =============================================================================
# FIREBASE / FCM PUSH NOTIFICATIONS (optional — leave APP_FCM_ENABLED=false to skip)
# Required only if you want push notifications on the dealer mobile app
# when the app is closed or in the background.
# When APP_FCM_ENABLED=true, set either APP_FCM_CREDENTIALS_PATH (file path)
# OR APP_FCM_CREDENTIALS_JSON_BASE64 (base64-encoded JSON) — not both.
# =============================================================================

APP_FCM_ENABLED=false
APP_FCM_PROJECT_ID=
# Option A — path to service_account.json on the host machine
APP_FCM_CREDENTIALS_PATH=
# Option B — base64-encoded content of service_account.json
# Generate with: base64 -w 0 service_account.json
APP_FCM_CREDENTIALS_JSON_BASE64=

# =============================================================================
# ANALYTICS / MONITORING (optional)
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
